.gitignore

# Local env — secrets must come from Railway Variables, not baked into image
.env
.env.*

# Dev / editor noise
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
coverage
*.tsbuildinfo

# Docker files themselves
Dockerfile
.dockerignore
